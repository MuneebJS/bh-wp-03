diff --git a/themes/insynia/style.css b/themes/insynia/style.css
new file mode 100644
index 0000000..3f94b4e
--- /dev/null
+++ b/themes/insynia/style.css
@@ -0,0 +1,223 @@
+/*
+Theme Name: Insynia
+Theme URI: https://github.com/insynia/insynia-theme
+Author: Insynia
+Author URI: https://insynia.com
+Description: Insynia is a fresh, minimal WordPress starter theme with a modern, clean design. Built for simplicity and performance.
+Requires at least: 6.4
+Tested up to: 6.9
+Requires PHP: 7.4
+Version: 1.0.0
+License: GNU General Public License v2 or later
+License URI: http://www.gnu.org/licenses/gpl-2.0.html
+Text Domain: insynia
+Tags: blog, minimal, modern, clean, one-column, custom-colors, custom-menu, featured-images, translation-ready
+*/
+
+/* ==========================================================================
+   Reset & Base
+   ========================================================================== */
+
+*,
+*::before,
+*::after {
+	box-sizing: border-box;
+}
+
+html {
+	font-size: 100%;
+	scroll-behavior: smooth;
+	-webkit-text-size-adjust: 100%;
+}
+
+body {
+	margin: 0;
+	padding: 0;
+	font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen, Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
+	font-size: 1rem;
+	line-height: 1.7;
+	color: #1a1a2e;
+	background-color: #fafafa;
+}
+
+/* ==========================================================================
+   Typography
+   ========================================================================== */
+
+h1, h2, h3, h4, h5, h6 {
+	margin: 0 0 0.75em;
+	font-weight: 600;
+	line-height: 1.25;
+	color: #0f0f23;
+	text-wrap: pretty;
+}
+
+h1 { font-size: clamp(2rem, 5vw, 3rem); }
+h2 { font-size: clamp(1.5rem, 3.5vw, 2.25rem); }
+h3 { font-size: clamp(1.25rem, 2.5vw, 1.75rem); }
+h4 { font-size: 1.25rem; }
+h5 { font-size: 1.125rem; }
+h6 { font-size: 1rem; }
+
+p {
+	margin: 0 0 1.25em;
+	text-wrap: pretty;
+}
+
+a {
+	color: #6c63ff;
+	text-decoration: underline;
+	text-decoration-thickness: 1px;
+	text-underline-offset: 0.15em;
+	transition: color 0.2s ease;
+}
+
+a:hover,
+a:focus {
+	color: #4f46e5;
+}
+
+/* ==========================================================================
+   Layout
+   ========================================================================== */
+
+.site {
+	display: flex;
+	flex-direction: column;
+	min-height: 100vh;
+}
+
+.site-content {
+	flex: 1;
+}
+
+.container {
+	width: 100%;
+	max-width: 1200px;
+	margin-inline: auto;
+	padding-inline: clamp(1rem, 5vw, 2.5rem);
+}
+
+/* ==========================================================================
+   Header
+   ========================================================================== */
+
+.site-header {
+	padding: 1.5rem 0;
+	border-bottom: 1px solid #e8e8f0;
+	background-color: #ffffff;
+}
+
+.site-header .container {
+	display: flex;
+	align-items: center;
+	justify-content: space-between;
+	gap: 1rem;
+}
+
+.site-branding {
+	display: flex;
+	flex-direction: column;
+}
+
+.site-title {
+	margin: 0;
+	font-size: 1.375rem;
+	font-weight: 700;
+	line-height: 1.2;
+	letter-spacing: -0.02em;
+}
+
+.site-title a {
+	color: inherit;
+	text-decoration: none;
+}
+
+.site-title a:hover {
+	color: #6c63ff;
+}
+
+.site-description {
+	margin: 0;
+	font-size: 0.875rem;
+	color: #6b7280;
+}
+
+/* ==========================================================================
+   Main Content
+   ========================================================================== */
+
+.site-main {
+	padding: clamp(3rem, 8vw, 6rem) 0;
+}
+
+/* ==========================================================================
+   Hero / Hello World
+   ========================================================================== */
+
+.hero {
+	text-align: center;
+	padding: clamp(4rem, 12vw, 8rem) 0;
+}
+
+.hero-greeting {
+	display: inline-block;
+	font-size: clamp(3rem, 8vw, 5.5rem);
+	font-weight: 700;
+	letter-spacing: -0.03em;
+	background: linear-gradient(135deg, #6c63ff 0%, #4f46e5 50%, #7c3aed 100%);
+	-webkit-background-clip: text;
+	-webkit-text-fill-color: transparent;
+	background-clip: text;
+	line-height: 1.1;
+	margin-bottom: 1.5rem;
+}
+
+.hero-tagline {
+	font-size: clamp(1rem, 2.5vw, 1.25rem);
+	color: #6b7280;
+	max-width: 480px;
+	margin-inline: auto;
+}
+
+/* ==========================================================================
+   Footer
+   ========================================================================== */
+
+.site-footer {
+	padding: 2rem 0;
+	border-top: 1px solid #e8e8f0;
+	background-color: #ffffff;
+	font-size: 0.875rem;
+	color: #6b7280;
+	text-align: center;
+}
+
+.site-footer a {
+	color: #6b7280;
+}
+
+.site-footer a:hover {
+	color: #6c63ff;
+}
+
+/* ==========================================================================
+   Focus Styles (Accessibility)
+   ========================================================================== */
+
+:focus-visible {
+	outline: 2px solid #6c63ff;
+	outline-offset: 3px;
+	border-radius: 2px;
+}
+
+/* ==========================================================================
+   Responsive
+   ========================================================================== */
+
+@media (max-width: 640px) {
+	.site-header .container {
+		flex-direction: column;
+		align-items: flex-start;
+	}
+}
